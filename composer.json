{
  "name": "pseudohat/educaid",
  "description": "EducAid web application",
  "type": "project",
  "require": {
    "php": ">=8.0",
    "ext-pgsql": "*",
    "ext-pdo_pgsql": "*",
    "ext-gd": "*",
    "ext-zip": "*",
     "phpmailer/phpmailer": "^6.8",
    "tecnickcom/tcpdf": "^6.7",
    "phpoffice/phpspreadsheet": "^1.29"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
     ,
     "classmap": [
       "config/",
       "includes/"
     ]
  }
    ,
    "scripts": {
      "post-install-cmd": [
        "composer dump-autoload -o"
      ],
      "post-update-cmd": [
        "composer dump-autoload -o"
      ]
    }
}
