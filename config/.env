# Localhost environment configuration for EducAid

###############################################
# Core App
###############################################
APP_NAME=EducAid
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/EducAid

###############################################
# Database (PostgreSQL Localhost)
###############################################
DB_HOST=localhost
DB_PORT=5432
DB_NAME=educaid
DB_USER=postgres
DB_PASSWORD=postgres

###############################################
# reCAPTCHA
###############################################
RECAPTCHA_SITE_KEY=replace_me_site_key
RECAPTCHA_SECRET_KEY=replace_me_secret_key
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_V2_SITE_KEY=replace_me_v2_site_key
RECAPTCHA_V2_SECRET_KEY=replace_me_v2_secret_key

###############################################
# SMTP / Email (Local defaults)
###############################################
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_ENCRYPTION=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=educaid@localhost
SMTP_FROM_NAME="EducAid"
MAIL_FROM_ADDRESS=${SMTP_FROM_EMAIL}
MAIL_FROM_NAME="EducAid"

###############################################
# Session Management
###############################################
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_ABSOLUTE_TIMEOUT_HOURS=8
SESSION_WARNING_BEFORE_LOGOUT_SECONDS=120
SESSION_REMEMBER_ME_DAYS=30

###############################################
# Optional
###############################################
GEMINI_API_KEY=replace_me_gemini_api_key